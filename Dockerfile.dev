FROM node:22-alpine

WORKDIR /app

# Install docker CLI for compose/container management
RUN apk add --no-cache docker-cli docker-cli-compose

# Install frontend deps
COPY package.json package-lock.json ./
RUN npm ci

# Install backend deps
COPY server/package.json server/package-lock.json ./server/
RUN cd server && npm ci

# Source is volume-mounted at runtime for hot reload
EXPOSE 7710 7711

# Start both frontend (Vite) and backend (tsx watch) in parallel
CMD sh -c "cd /app/server && npm run dev & cd /app && npm run dev -- --host 0.0.0.0"
